# Copy this file to `.env` and fill values, OR export variables in your shell.
# The app reads `GEMINI_API_KEY` and `FIREBASE_DATABASE_URL` from the environment.

# Google AI Studio — required for Cortex AI /api/analyze
GEMINI_API_KEY=

# Firebase Realtime Database root URL (no trailing slash)
# Example: https://YOUR-PROJECT-default-rtdb.REGION.firebasedatabase.app
FIREBASE_DATABASE_URL=
